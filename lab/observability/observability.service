[Unit]
Description=Marsey lab observability stack (Docker Compose)
Documentation=file:///opt/observability/README.md
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/observability
# Compose loads .env from WorkingDirectory for ${VAR} interpolation
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose stop
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
