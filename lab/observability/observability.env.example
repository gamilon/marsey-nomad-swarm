# Copy to observability.env next to docker-compose.yml and fill in real values.
#   cp observability.env.example observability.env
# Do not commit observability.env.

# Grafana admin (login at https://grafana.marsey.tel)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana

# MinIO (S3 for Loki) — lab only; change before first `compose up`
MINIO_ROOT_USER=loki
MINIO_ROOT_PASSWORD=change-me-minio

# Nomad ACL token for Prometheus scrape (node:read / agent:read is enough).
# Create with: nomad acl token create -name=observability-metrics -policy=observability-metrics
NOMAD_TOKEN=

# Edge basic auth for https://loki.marsey.tel and https://prometheus.marsey.tel
# Used only when generating nginx/htpasswd (see README); not read by compose directly.
EDGE_BASIC_AUTH_USER=lab
EDGE_BASIC_AUTH_PASSWORD=change-me-edge
